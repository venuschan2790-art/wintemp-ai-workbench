AI_PROVIDER=openai

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PROXY_URL=http://127.0.0.1:7897

# 如果切换到魔芋 API，把 AI_PROVIDER 改成 moyu，并填写魔芋后台提供的信息。
# MOYU_API_FORMAT 默认为 chat，适合 OpenAI-compatible 的 /chat/completions 接口。
MOYU_API_KEY=your-moyu-api-key-here
MOYU_MODEL=your-moyu-model-name
MOYU_BASE_URL=https://your-moyu-api-base-url
MOYU_API_FORMAT=chat
MOYU_API_PATH=/chat/completions
