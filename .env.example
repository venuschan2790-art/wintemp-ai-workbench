AI_PROVIDER=openai

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PROXY_URL=http://127.0.0.1:7897

# 如果切换到魔芋 API，把 AI_PROVIDER 改成 moyu，并填写魔芋后台提供的信息。
# MOYU_API_FORMAT 默认为 chat，适合魔芋的 /pg/chat/completions 接口。
MOYU_API_KEY=your-moyu-api-key-here
MOYU_MODEL=gpt-4o
MOYU_BASE_URL=https://www.moyu.info
MOYU_API_FORMAT=chat
MOYU_API_PATH=/pg/chat/completions

# 产品营销场景图 Agent 的直接出图功能。
# 如果使用魔芋图片模型，通常只需要配置 IMAGE_MODEL，其他会默认复用魔芋 API Key 和 Base URL。
IMAGE_MODEL=jimeng_t2i_v31
IMAGE_BASE_URL=https://www.moyu.info
IMAGE_API_PATH=/pg/images/generations
